CN_Function::CN_Function()
{
	pPiezoDevice = new CPiezoDevice();

	m_nRtn_Err_Code = -1;

	int i,nCnt;
	int nLine,nMachine,nHead,nMaterial,nTarget;	

	for ( int nModuleCount = 0; nModuleCount < MAX_MODULE; nModuleCount++ )
	{
		m_structModuleData_Get[nModuleCount].strModuleID = ""; 
		m_structModuleData_Set[nModuleCount].strModuleID = ""; 

		for ( int nHeadCount = 0; nHeadCount < MAX_NOZZLE; nHeadCount ++ )
		{
			m_structModuleData_Get[nModuleCount].nAmplitude_Offset = 0; 
			m_structModuleData_Get[nModuleCount].nDuty_Offset      = 0; 
			m_structModuleData_Get[nModuleCount].nFirst_Vol_Offset = 0; 
			m_structModuleData_Get[nModuleCount].nFrequecy_Offset  = 0; 
			m_structModuleData_Get[nModuleCount].nNegOffset_Offset = 0; 

			m_structModuleData_Set[nModuleCount].nAmplitude_Offset = 0; 
			m_structModuleData_Set[nModuleCount].nDuty_Offset      = 0; 
			m_structModuleData_Set[nModuleCount].nFirst_Vol_Offset = 0; 
			m_structModuleData_Set[nModuleCount].nFrequecy_Offset  = 0; 
			m_structModuleData_Set[nModuleCount].nNegOffset_Offset = 0; 



		}
	}

	for ( int nHeadCount = 0; nHeadCount < MAX_NOZZLE; nHeadCount ++ )
	{
		m_structNParam[nHeadCount].m_strModuleID ="";
		m_structNParam[nHeadCount].m_nNAmplitude_Offset = 0;
		m_structNParam[nHeadCount].m_dNDuty_Offset = 0;
		m_structNParam[nHeadCount].m_nNFirstVoltage_Offset = 0;
		m_structNParam[nHeadCount].m_nNNegOffset_Offset = 0;

		for ( int nPatternCount = 0; nPatternCount < 256 ; nPatternCount++)
		{
			m_structNParam[nHeadCount].m_nNAmplitude[nPatternCount] = 0;
			m_structNParam[nHeadCount].m_dNDuty[nPatternCount] = 0;
			m_structNParam[nHeadCount].m_nNFirstVoltage[nPatternCount] = 0;
			m_structNParam[nHeadCount].m_nNNegOffset[nPatternCount] = 0;
		}
	}

	m_hTimeEvent = CreateEvent(NULL,FALSE,FALSE,NULL);
}

CN_Function::~CN_Function()
{

}

int CN_Function::Set_NParameter(int nSlaveNo, PIEZO_PARAM Param)
{
	m_nRtn_Err_Code = -1;
	pPiezoDevice->m_nSlave = nSlaveNo;

	if(!pPiezoDevice->Connect())
	{
		return	m_nRtn_Err_Code = 1;
	}

	if(!pPiezoDevice->Write_Param(Param))
	{
		return m_nRtn_Err_Code = 2;
	}

	return m_nRtn_Err_Code; 
}

int CN_Function::Get_NParameter(int nSlaveNo, PIEZO_PARAM Param)
{
	m_nRtn_Err_Code = -1;
	pPiezoDevice->m_nSlave = nSlaveNo;

	if(!pPiezoDevice->Connect())
	{
		return	m_nRtn_Err_Code = 1;
	}

	if(!pPiezoDevice->Read_Param(&Param))
	{
		return m_nRtn_Err_Code = 2;
	}

	return m_nRtn_Err_Code; 
}

BOOL CN_Function::N_Initialize()
{	
	pPiezoDevice->m_nPort  = N_PORT;
	pPiezoDevice->m_nSlave = 0;
	pPiezoDevice->m_nBaudrate = 115200;

	
	pPiezoDevice->Set_Port(pPiezoDevice->m_nPort, pPiezoDevice->m_nBaudrate, pPiezoDevice->m_nSlave);

	return TRUE;
}

void CN_Function::Copy_NParameter(int nSlaveNo, PIEZO_PARAM ParamOrg, PIEZO_PARAM ParamDest)
{
	int nSize = sizeof(ParamDest);
	memcpy(&ParamDest,&ParamOrg,nSize);
}

int CN_Function::Read_Module_DB(CString strRecipeNo)
{
	CMainFrame *pFrame = (CMainFrame*)AfxGetMainWnd();
	CP8CA_LcDispDoc *pDoc = (CP8CA_LcDispDoc*)pFrame->GetActiveDocument();

	int ReturnCode = -1;
	FILE *fp;
	CString strPathName;
	char ch[512];
	int i=0,j=0;
	CString strTemp = "";
	int nCnt,nLength;

	m_mmTimer.Reset();
	m_mmTimer.Start(1,1,m_hTimeEvent);

	strPathName.Format("D:\\TOP\\P8CA_LC\\N_MODULE_DB\\%s.csv", strRecipeNo);

	if((fp = fopen((char*)(LPCSTR)strPathName,"r")) == NULL)
	{
		AfxMessageBox("File not found!", MB_ICONQUESTION);
		return ReturnCode;
	}

	fgets(ch,1024,fp);

	strTemp = CString(ch);

	while( !feof( fp ) )
	{
		if( i == MAX_RECIPE )
		{
			break;
		}

		fgets(ch,1024,fp);

		strTemp = CString(ch);

		nLength = strTemp.GetLength();
		nCnt = strTemp.FindOneOf(",");

//		strTemp = strTemp.Mid(nCnt+1,nLength);
//		nCnt = strTemp.FindOneOf(",");

		m_structModuleData_Get[i].strModuleID = strTemp.Mid(0,nCnt);
		m_structModuleData_Set[i].strModuleID = m_structModuleData_Get[i].strModuleID; 

		strTemp = strTemp.Mid(nCnt+1,nLength);
		nCnt = strTemp.FindOneOf(",");

		m_structModuleData_Get[i].nAmplitude_Offset = atoi(strTemp.Mid(0,nCnt));
		m_structModuleData_Set[i].nAmplitude_Offset = m_structModuleData_Get[i].nAmplitude_Offset; 

		strTemp = strTemp.Mid(nCnt+1,nLength);	
		nCnt = strTemp.FindOneOf(",");

		m_structModuleData_Get[i].nNegOffset_Offset = atoi(strTemp.Mid(0,nCnt));
		m_structModuleData_Set[i].nNegOffset_Offset = m_structModuleData_Get[i].nNegOffset_Offset;

		strTemp = strTemp.Mid(nCnt+1,nLength);	
		nCnt = strTemp.FindOneOf(",");

		m_structModuleData_Get[i].nDuty_Offset = atoi(strTemp.Mid(0,nCnt));
		m_structModuleData_Set[i].nDuty_Offset = m_structModuleData_Get[i].nDuty_Offset;

		strTemp = strTemp.Mid(nCnt+1,nLength);	
		nCnt = strTemp.FindOneOf(",");

		m_structModuleData_Get[i].nFirst_Vol_Offset = atoi(strTemp.Mid(0,nCnt));
		m_structModuleData_Set[i].nFirst_Vol_Offset = m_structModuleData_Get[i].nFirst_Vol_Offset; 

		i++;
	}
	fclose(fp);

	m_mmTimer.Stop();

	m_strNLog.Format("Read_Module_DB %s %d",strRecipeNo,m_mmTimer.GetTotalMilliseconds());
	Save_N_Log(0,m_strNLog);

	return ReturnCode;
}

int CN_Function::Save_Module_DB(CString strRecipeNo)
{
	CMainFrame *pFrame = (CMainFrame*)AfxGetMainWnd();
	CP8CA_LcDispDoc *pDoc = (CP8CA_LcDispDoc*)pFrame->GetActiveDocument();

	int ReturnCode = -1;
	FILE *fp;
	CString strPathName;
	int i,nLength,nCnt;
	int nLine,nMachine,nHead,nMaterial,nTarget;

	CFileFind filefind;
	CFileException e;
	CString strText;

	CTime t = CTime::GetCurrentTime();

	m_mmTimer.Reset();
	m_mmTimer.Start(1,1,m_hTimeEvent);


	CString strFileName, strDirName, str;
	BOOL bIsDir = FALSE;
	BOOL bContinue = TRUE;

	// 디렉토리 탐색
	
	filefind.FindFile("D:\\TOP\\P8CA_LC\\*.*");
	bIsDir = FALSE;
	bContinue = TRUE;
	while(bContinue)
	{
		bContinue = filefind.FindNextFile();
		if(filefind.IsDirectory())
		{
			strDirName = filefind.GetFileName();
			if(strDirName == "N_MODULE_DB")
			{
				bIsDir = TRUE;
				break;
			}
		}
	}
	
	filefind.Close();
	
	if(!bIsDir)	_mkdir("D:\\TOP\\P8CA_LC\\N_MODULE_DB");
	
	strPathName.Format("D:\\TOP\\P8CA_LC\\N_MODULE_DB\\%s.csv", strRecipeNo);

	fp = fopen(strPathName, "wt");

	if(fp != NULL)
	{
		fprintf(fp,"%s,","ModuleID#1");
		fprintf(fp,"%s,","Amplitude_Offset");
		fprintf(fp,"%s,","NegOffset_Offset");
		fprintf(fp,"%s,","Duty_Offset");
		fprintf(fp,"%s,","First_Vol_Offset");
		fprintf(fp,"\n");

		for ( int nModuleCount = 0; nModuleCount < MAX_MODULE; nModuleCount++ )
		{
			fprintf(fp,"%s,",m_structModuleData_Set[nModuleCount].strModuleID);
			fprintf(fp,"%d,",m_structModuleData_Set[nModuleCount].nAmplitude_Offset);
			fprintf(fp,"%d,",m_structModuleData_Set[nModuleCount].nNegOffset_Offset);
			fprintf(fp,"%f,",m_structModuleData_Set[nModuleCount].nDuty_Offset);
			fprintf(fp,"%d,",m_structModuleData_Set[nModuleCount].nFirst_Vol_Offset);
			fprintf(fp,"\n");
		}
	}
	else
	{
		
	}
	fclose(fp);

	m_mmTimer.Stop();

	m_strNLog.Format("Save_Module_DB %s %d",strRecipeNo,m_mmTimer.GetTotalMilliseconds());
	Save_N_Log(0,m_strNLog);

	return ReturnCode;
}

