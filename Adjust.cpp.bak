	ThBal[BALID2].JobStep = 0;
	ThBal[BALID3].JobStep = 0;
	ThBal[BALID4].JobStep = 0;
	ThBal[BALID5].JobStep = 0;
	ThBal[BALID6].JobStep = 0;
	ThBal[BALID7].JobStep = 0;
	ThBal[BALID8].JobStep = 0;
	//
