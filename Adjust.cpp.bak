void CAdjust::SelectLanguage()
{
	CMainFrame *pFrame = (CMainFrame*)AfxGetMainWnd();
	CP8CA_LcDispView* pView = (CP8CA_LcDispView*)pFrame->GetActiveView();

	if(pView->m_nLanguage == 0)	//ehji 140309
	{
		SetDlgItemText(IDC_CMD_TITLE,				_T("УјСЄ & СЖСЄ"));
		SetDlgItemText(IDC_CALIBRATION_APPLY,				_T("Calibration АшЛъФЁ РћПы"));
		SetDlgItemText(IDC_BAL_MODE_SET,				_T("BALANCE MODE : СЄЛѓ"));
		SetDlgItemText(IDC_BALANCE_CAL,				_T("BALANCE БГСЄ"));
		SetDlgItemText(IDC_BTN_PUMP_INITIAL,				_T("ЦпЧС УЪБтШ­"));
		SetDlgItemText(IDC_BTN_SEQ_INITIAL,				_T("УјСЄАсАњ БзЗЁЧС"));
		SetDlgItemText(IDC_CMD_ADJUST,				_T("ХфУтЗЎ СЖСЄ"));
		SetDlgItemText(IDC_LABEL13,				_T("СЖСЄ ПРТї(%)"));
		SetDlgItemText(IDC_CMD_MEASURE,				_T("ХфУтЗЎ УјСЄ"));
		SetDlgItemText(IDC_LABEL37,				_T("УјСЄ ШНМі(ШИ)"));
		SetDlgItemText(IDC_CMD_DROP_COUNTING,				_T("Drop ФЋПюЦЎ МТЦУ"));
		SetDlgItemText(IDC_APD_REPORT,				_T("APD DATA КИАэ OFF"));
		SetDlgItemText(IDC_CMD_RETURN,				_T("РЬРќ Ш­Ищ"));
	}

