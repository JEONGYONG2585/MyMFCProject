					m_structCell_Info_Lc.m_dSealLine_Start_X[i], m_structCell_Info_Lc.m_dSealLine_Start_Y[i], m_structCell_Info_Lc.m_dSealLine_End_X[i], m_structCell_Info_Lc.m_dSealLine_End_Y[i]);
				fprintf(fp, "%s\n", str);
				str.Empty();
