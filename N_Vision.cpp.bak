				str.Format("%d,%d,%d,%d,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f", i+1, m_structCell_Info_Lc.m_nDrop_Count[i], m_structCell_Info_Lc.m_nLine_Count[i], m_structCell_Info_Lc.m_nDrop_Count_Y[i], 
