void __stdcall Func_RcvDisconnect(void)
{
	// Server ŅÕ Ņ¨įŠ «ōŃ¶Ķ» ĽůŇ¬ł¶ ľŲĹŇ«—īŔ.
	TRACE(_T("Disconnet"));
