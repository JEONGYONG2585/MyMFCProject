//2010.05.17 by tskim EC&RMS
typedef struct tagECInform
{
	double m_dDmyPos_S[MAX_NOZZLE];		// DMY POS S	S1~S16 ДѕЙЬ ХфУт РЇФЁ l4	mm
	double m_dDmyPos_Col;				// DMY POS COL	Column ДѕЙЬ ХфУт РЇФЁ l4	mm
	double m_dMeasPos_S[MAX_NOZZLE];	// MEAS POS S	S1~S16 УјСЄ РЇФЁ l4	mm
	double m_dMeasPos_Col;				// MEAS POS COL	Column УјСЄ РЇФЁ l4	mm
	double m_dMutePos_Col[3];			// MUTE POS COL	Column Muting РЇФЁ 1~3 l4	mm
	double m_dMarkPos_S1;				// ALIGN POS S1	S1 Mark Align ШЎРЮ РЇФЁ l4	mm
	double m_dMarkPos_S16;				// ALIGN POS S16	S16 Mark Align ШЎРЮ РЇФЁ l4	mm
	double m_dMarkPos_Col;				// ALIGN POS COL	Column Mark Align ШЎРЮ РЇФЁ l4	mm
	double m_dSensingTime[3];			// SENS TIME	Sensor АЈСі НУАЃ 1~3 l4	msec
	double m_dCntPos_Col;				// CNT POS COL	Column СпНЩ РЇФЁ l4	mm
	double m_dOperPos_Col;				// OP POS COL	Column РлОїРк РЇФЁ  l4	mm
	double m_dLoadPos_F;				// LD POS F	ЙнУт,Рд РЇФЁ Front l4	mm
	double m_dLoadPos_R;				// LD POS R	ЙнУт,Рд РЇФЁ Rear l4	mm
	double m_dSupPos_S[MAX_NOZZLE];		// SUP POS S	S1~S16 СпОг АјБо РЇФЁ l4	mm
	double m_dSupPos_Col;				// SUP POS COL	Column СпОг АјБо РЇФЁ l4	mm
	double m_dSupAmount;				// SUP PARA 1	СпОгАјБоЗЎ l2	g
	double m_dSupTime;					// SUP PARA 2	СпОгАјБоНУАЃ l2	sec
	double m_dTriggerTime[3];			// TRIGGER TIME	Trigger Time1~3 l2	sec
	double m_dInputLimit[2];			// INPUT LIMIT	ХѕРд СІЧб НУАЃ1~2 l2	sec
	double m_dColSpd;					//COL MOVE SPD	Column РЬЕП МгЕЕ l2	mm/sec
} EC_INFORM;

