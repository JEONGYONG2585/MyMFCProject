	DDX_Control(pDX, IDC_WARMUP_MODE2, m_ctrlWarmupMode2);
	DDX_Control(pDX, IDC_CMD_RETURN, m_ctrlReturn);
	DDX_Control(pDX, IDC_WARMUP_RUN, m_ctrlWarmupRun);
